name: Auto Claude Market Review

on:
  schedule:
    - cron: '40 6 * * 1-5'    # 국내: 월~금 15:40 KST (= 06:40 UTC)
    - cron: '30 21 * * 1-5'   # 해외: 화~토 06:30 KST (= 전날 21:30 UTC)
  workflow_dispatch:           # 수동 실행 버튼
    inputs:
      market:
        description: '분석할 시장 (kr = 국내 / us = 해외)'
        required: true
        default: 'kr'
        type: choice
        options: [kr, us]

jobs:
  review:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install packages
        run: pip install -r requirements.txt

      - name: Determine market
        id: mkt
        run: |
          if [ "${{ github.event_name }}" = "workflow_dispatch" ]; then
            echo "market=${{ github.event.inputs.market }}" >> "$GITHUB_OUTPUT"
          elif [ "${{ github.event.schedule }}" = "40 6 * * 1-5" ]; then
            echo "market=kr" >> "$GITHUB_OUTPUT"
          else
            echo "market=us" >> "$GITHUB_OUTPUT"
          fi

      - name: Generate & publish review
        env:
          FIREBASE_KEY: ${{ secrets.FIREBASE_KEY }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: python generate_review.py --market ${{ steps.mkt.outputs.market }}
